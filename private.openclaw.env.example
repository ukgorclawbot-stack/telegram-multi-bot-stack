TELEGRAM_BOT_TOKEN=replace_with_private_openclaw_bot_token
BOT_ENTRYPOINT=group_bot.py
BOT_ROLE=openclaw
BOT_MODE=dispatcher
BOT_DISPLAY_NAME="OpenClaw Private"
TASK_COMMAND=task
ALLOW_DM_TASKS=true
ENABLE_DIRECT_PRIVATE_TASKS=true
PRIVATE_TASK_MODE=manual
ALLOW_GROUP_CHAT=false
ALLOWED_USER_IDS=123456789
GROUP_TASK_DB_PATH=/Users/your_user/telegram-bot-stack-open/group-tasks.sqlite3
MEMORY_DB_PATH=/Users/your_user/telegram-bot-stack-open/bot-memory.sqlite3
PERSISTED_HISTORY_LIMIT=80
MAX_CONTEXT_MESSAGES=16
ENABLE_SHARED_MEMORY_LOG=true
SHARED_MEMORY_DIR=/Users/your_user/telegram-bot-stack-open/shared-memory
MEMORY_TIMEZONE=Asia/Shanghai
ALLOW_LONG_TERM_MEMORY_WRITE=true
LONG_TERM_MEMORY_SCRIPT_PATH=/Users/your_user/telegram-bot-stack-open/scripts/shared-memory-write.sh
WORKDIR=/Users/your_user/.openclaw/workspace
PRIVATE_DIRECT_WORKDIR=/Users/your_user
RUNNER_BACKEND=openclaw_router
PRIVATE_DIRECT_RUNNER_BACKEND=openclaw_agent
PRIVATE_DIRECT_OPENCLAW_AGENT_ID=main
RUNNER_TIMEOUT_SECS=900
OPENCLAW_BIN=/opt/homebrew/bin/openclaw
OPENCLAW_ROUTER_CODING_AGENT=codex
OPENCLAW_ROUTER_DOCS_AGENT=gemini
OPENCLAW_ROUTER_DEFAULT_AGENT=codex
