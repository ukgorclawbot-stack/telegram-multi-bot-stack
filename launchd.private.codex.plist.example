<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.example.telegrambots.telegram-private-codex</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd /Users/your_user/telegram-bot-stack-open &amp;&amp; ./run_role_bot.sh /Users/your_user/telegram-bot-stack-open/private.codex.env</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>WorkingDirectory</key>
  <string>/Users/your_user/telegram-bot-stack-open</string>
  <key>StandardOutPath</key>
  <string>/Users/your_user/telegram-bot-stack-open/private-codex.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/your_user/telegram-bot-stack-open/private-codex.stderr.log</string>
</dict>
</plist>
